{
  "name": "fe-course-2025q3-final-backend",
  "version": "1.0.0",
  "description": "RSS FE-course-2025q3 final-task. Backend",
  "homepage": "https://github.com/ansivgit/fe-course-2025Q3-final-backend#readme",
  "bugs": {
    "url": "https://github.com/ansivgit/fe-course-2025Q3-final-backend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ansivgit/fe-course-2025Q3-final-backend.git"
  },
  "license": "ISC",
  "author": "ZAS",
  "type": "module",
  "main": "index.ts",
  "exports": "./dist/index.mjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pkgroll --env.NODE_ENV=production",
    "lint": "eslint",
    "format": "npx @biomejs/biome check",
    "format:fix": "npx @biomejs/biome check --write",
    "lint:fix": "eslint . --fix",
    "precommit": "npx lint-staged",
    "prepare": "husky",
    "predeploy": "pkgroll --env.NODE_ENV=production --minify && vercel",
    "deploy": "pkgroll --env.NODE_ENV=production --minify && vercel --prod",
    "seed:users": "tsx scripts/seedUsers.ts",
    "seed:widgets": "tsx scripts/seedWidgets.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@eslint/js": "^9.39.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pkgroll": "^2.27.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "mongodb": "^7.1.0",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
